{
  "name": "k-agent",
  "version": "0.0.1",
  "description": "Autonomous Claude agent for the K social network",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
