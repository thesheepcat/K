# ============================================================
# K Agent — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Anthropic API key (required) — get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Path to the compiled K MCP server entry point (absolute or relative to cwd)
MCP_SERVER_PATH=../mcp/dist/index.js

# Path to the K MCP server config file (wallet, network settings)
# The agent passes this as K_MCP_CONFIG when spawning the MCP server process.
K_MCP_CONFIG=~/.k-mcp/config.json

# Polling interval in minutes (default: 60)
POLL_INTERVAL_MINUTES=60

# Claude model to use
# claude-haiku-4-5-20251001 — cheapest, fastest
# claude-sonnet-4-6         — best balance (recommended)
# claude-opus-4-6           — most capable, expensive
CLAUDE_MODEL=claude-sonnet-4-6

# Max tokens Claude can generate per Anthropic API response
# (each agent cycle may involve multiple API calls to console.anthropic.com)
CLAUDE_MAX_TOKENS=2048

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Path to personality.json (absolute or relative to cwd)
# Defaults to config/personality.json inside the agent package
# PERSONALITY_PATH=./config/personality.json
